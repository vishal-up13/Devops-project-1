pipeline {
    agent any

    environment {
        // Your exact Docker Hub username and repository path
        DOCKER_IMAGE = "vishal4284/website:latest"
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'master',
                    url: 'https://github.com'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t $DOCKER_IMAGE ."
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    '''
                }
            }
        }

        stage('Push Image') {
            steps {
                sh "docker push $DOCKER_IMAGE"
            }
        }

        stage('Scheduled Release Gate') {
            steps {
                script {
                    // Fetch the current day of the month from the server clock
                    def currentDay = sh(script: "date +%d", returnStdout: true).trim()
                    
                    // SIMULATION MODE: Set to "05" to force deployment today.
                    // IMPORTANT: Change back to "25" before final submission!
                    if (currentDay == "05") {
                        echo "Today is the 5th! Simulation match. Proceeding with the production cluster deployment..."
                    } else {
                        echo "Current day is ${currentDay}. Production deployments are blocked until the 25th. Skipping release step cleanly."
                        currentBuild.result = 'SUCCESS'
                        return
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            when {
                // SIMULATION MODE: Matches today's date to allow execution
                // IMPORTANT: Change back to "25" before final submission!
                expression { sh(script: "date +%d", returnStdout: true).trim() == "05" }
            }
            steps {
                sh '''
                    kubectl apply -f k8s/deployment.yaml
                    kubectl apply -f k8s/service.yaml
                '''
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS ✅"
        }
        failure {
            echo "Pipeline FAILED ❌"
        }
    }
}
